<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/returnButton"
                android:layout_height="50dp"
                android:layout_width="50dp"
                android:src="@drawable/outline_arrow_top_left_24"
                app:tint="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agregar Movimiento"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp" />


        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de movimiento"
            android:textStyle="bold"
            android:textColor="#BDBDBD"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/tipoMovimeinto"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#1E1E1E"
            android:padding="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cantidad"
            android:textStyle="bold"
            android:textColor="#BDBDBD"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/cantidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E1E1E"
            android:hint="Ingrese cantidad"
            android:textColorHint="#757575"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/cuentaSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/cuenta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E1E1E"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/categoria"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E1E1E"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta origen"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/cuentaOrigen"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E1E1E"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta destino"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/cuentaDestino"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E1E1E"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:hint="Ingrese descripción"
                android:textColorHint="#757575"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:padding="14dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textStyle="bold"
                android:textColor="#BDBDBD"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/fecha"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text=""/>

            <Button
                android:id="@+id/guardar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:backgroundTint="#00C853"
                android:text="Guardar Movimiento"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>